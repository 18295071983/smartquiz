{
  "name": "CSV模板",
  "description": "CSV格式导出模板，适合数据分析",
  "format": "CSV",
  "fields": [
    "questionText",
    "optionA",
    "optionB",
    "optionC",
    "optionD",
    "correctAnswer",
    "explanation",
    "questionType",
    "difficulty",
    "category"
  ],
  "fieldMappings": {
    "questionText": "题目",
    "optionA": "选项A",
    "optionB": "选项B",
    "optionC": "选项C",
    "optionD": "选项D",
    "correctAnswer": "正确答案",
    "explanation": "解析",
    "questionType": "题型",
    "difficulty": "难度",
    "category": "分类"
  },
  "config": {
    "includeAnswers": true,
    "includeExplanations": true,
    "delimiter": ",",
    "quoteCharacter": "\""
  },
  "template": "{{fields}}\n{{questions}}"
}
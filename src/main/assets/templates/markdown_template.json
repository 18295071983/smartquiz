{
  "name": "Markdown模板",
  "description": "Markdown格式导出模板，适合文档编写",
  "format": "MARKDOWN",
  "fields": [
    "questionText",
    "optionA",
    "optionB",
    "optionC",
    "optionD",
    "correctAnswer",
    "explanation",
    "questionType",
    "difficulty",
    "category"
  ],
  "fieldMappings": {
    "questionText": "题目",
    "optionA": "选项A",
    "optionB": "选项B",
    "optionC": "选项C",
    "optionD": "选项D",
    "correctAnswer": "正确答案",
    "explanation": "解析",
    "questionType": "题型",
    "difficulty": "难度",
    "category": "分类"
  },
  "config": {
    "includeAnswers": true,
    "includeExplanations": true,
    "useHeadingLevels": true,
    "includeTableOfContents": true
  },
  "template": "# {{title}}\n\n## 导出信息\n\n- 导出时间: {{exportTime}}\n- 题目数量: {{questionCount}}\n\n## 题目列表\n\n{{questions}}\n\n## 导出完成\n\n导出时间: {{exportTime}}"
}
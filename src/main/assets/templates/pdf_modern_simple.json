{
  "name": "PDF现代简洁",
  "description": "现代简洁风格PDF模板，适合打印",
  "format": "PDF",
  "fields": [
    "questionText",
    "optionA",
    "optionB",
    "optionC",
    "optionD",
    "correctAnswer",
    "explanation",
    "analysis",
    "hint",
    "questionType",
    "difficulty",
    "category",
    "subCategory",
    "knowledgePoint",
    "tags",
    "source",
    "points",
    "timeLimit",
    "author"
  ],
  "fieldMappings": {
    "questionText": "题目",
    "optionA": "选项A",
    "optionB": "选项B",
    "optionC": "选项C",
    "optionD": "选项D",
    "correctAnswer": "正确答案",
    "explanation": "解析",
    "analysis": "详细解析",
    "hint": "提示",
    "questionType": "题型",
    "difficulty": "难度",
    "category": "分类",
    "subCategory": "子分类",
    "knowledgePoint": "知识点",
    "tags": "标签",
    "source": "来源",
    "points": "分值",
    "timeLimit": "时限(秒)",
    "author": "作者"
  },
  "config": {
    "includeAnswers": true,
    "includeExplanations": true,
    "pageSize": "A4",
    "font": "simkai.ttf",
    "fontSize": 12,
    "headingFontSize": 16,
    "margins": {
      "top": 40,
      "bottom": 40,
      "left": 40,
      "right": 40
    },
    "lineSpacing": 1.5,
    "headerEnabled": true,
    "footerEnabled": true,
    "pageNumberEnabled": true
  },
  "template": "{{title}}\n{{info}}\n{{questions}}\n{{footer}}"
}
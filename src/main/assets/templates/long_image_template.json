{
  "name": "长图片模板",
  "description": "长图片格式导出模板，适合分享",
  "format": "LONG_IMAGE",
  "fields": [
    "questionText",
    "optionA",
    "optionB",
    "optionC",
    "optionD",
    "correctAnswer",
    "explanation"
  ],
  "fieldMappings": {
    "questionText": "题目",
    "optionA": "选项A",
    "optionB": "选项B",
    "optionC": "选项C",
    "optionD": "选项D",
    "correctAnswer": "正确答案",
    "explanation": "解析"
  },
  "config": {
    "includeAnswers": true,
    "includeExplanations": true,
    "imageWidth": 3840,
    "textSize": 32,
    "backgroundColor": "#FFFFFF",
    "padding": 40
  },
  "template": "{{header}}\n{{questions}}\n{{footer}}"
}
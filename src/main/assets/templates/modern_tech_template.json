{
  "name": "现代科技",
  "description": "现代科技风格，适合技术类题目",
  "format": "HTML",
  "fields": [
    "questionText",
    "optionA",
    "optionB",
    "optionC",
    "optionD",
    "correctAnswer",
    "explanation",
    "analysis",
    "hint",
    "questionType",
    "difficulty",
    "category",
    "subCategory",
    "knowledgePoint",
    "tags",
    "source",
    "points",
    "timeLimit",
    "author"
  ],
  "fieldMappings": {
    "questionText": "题目",
    "optionA": "选项A",
    "optionB": "选项B",
    "optionC": "选项C",
    "optionD": "选项D",
    "correctAnswer": "正确答案",
    "explanation": "解析",
    "analysis": "详细解析",
    "hint": "提示",
    "questionType": "题型",
    "difficulty": "难度",
    "category": "分类",
    "subCategory": "子分类",
    "knowledgePoint": "知识点",
    "tags": "标签",
    "source": "来源",
    "points": "分值",
    "timeLimit": "时限(秒)",
    "author": "作者"
  },
  "config": {
    "includeAnswers": true,
    "includeExplanations": true,
    "groupByCategory": true,
    "includeCategories": true
  },
  "questionTemplate": "<div class=\"question-card\">\n  <div class=\"question-header\">\n    <h3 class=\"question-number\">Q{{questionNumber}}</h3>\n    <div class=\"question-meta\">\n      {{#if questionType}}<span class=\"question-type\">{{questionType}}</span>{{/if}}\n      {{#if difficulty}}<span class=\"difficulty-level\">Lv.{{difficulty}}</span>{{/if}}\n    </div>\n  </div>\n  <div class=\"question-content\">\n    <p class=\"question-text\">{{questionText}}</p>\n    {{#if options}}\n    <div class=\"options-grid\">\n      {{options}}\n    </div>\n    {{/if}}\n  </div>\n  <div class=\"question-actions\">\n    <button class=\"action-btn show-answer\">查看答案</button>\n    <button class=\"action-btn show-explanation\">查看解析</button>\n  </div>\n  <div class=\"answer-section\">\n    <div class=\"correct-answer\">\n      <span class=\"answer-label\">正确答案：</span>\n      <span class=\"answer-value\">{{correctAnswer}}</span>\n    </div>\n    {{#if explanation}}\n    <div class=\"explanation\">\n      <h4 class=\"section-title\">解析</h4>\n      <p>{{explanation}}</p>\n    </div>\n    {{/if}}\n    {{#if analysis}}\n    <div class=\"analysis\">\n      <h4 class=\"section-title\">详细解析</h4>\n      <p>{{analysis}}</p>\n    </div>\n    {{/if}}\n    {{#if hint}}\n    <div class=\"hint\">\n      <h4 class=\"section-title\">提示</h4>\n      <p>{{hint}}</p>\n    </div>\n    {{/if}}\n  </div>\n  <div class=\"question-footer\">\n    {{#if category}}<span class=\"footer-item\">{{category}}</span>{{/if}}\n    {{#if knowledgePoint}}<span class=\"footer-item\">{{knowledgePoint}}</span>{{/if}}\n    {{#if tags}}<span class=\"footer-item\">{{tags}}</span>{{/if}}\n  </div>\n</div>",
  "template": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>现代科技风格</title>\n<style>\n:root {\n  --primary-color: #0066ff;\n  --secondary-color: #00ccff;\n  --accent-color: #ff6600;\n  --background-color: #0a0a0a;\n  --card-color: #1a1a1a;\n  --text-color: #ffffff;\n  --text-secondary: #b0b0b0;\n  --border-color: #333333;\n  --success-color: #00ff88;\n  --warning-color: #ffaa00;\n  --error-color: #ff4444;\n  --gradient-primary: linear-gradient(135deg, var(--primary-color), var(--secondary-color));\n  --gradient-accent: linear-gradient(135deg, var(--accent-color), #ff9900);\n  --shadow: 0 8px 32px rgba(0, 102, 255, 0.3);\n  --border-radius: 12px;\n  --transition: all 0.3s ease;\n}\n\n* {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nbody {\n  font-family: 'Segoe UI', 'Microsoft YaHei', Arial, sans-serif;\n  line-height: 1.6;\n  color: var(--text-color);\n  background: var(--background-color);\n  background-image: \n    radial-gradient(circle at 25% 25%, rgba(0, 102, 255, 0.1) 0%, transparent 50%),\n    radial-gradient(circle at 75% 75%, rgba(0, 204, 255, 0.1) 0%, transparent 50%);\n  min-height: 100vh;\n  padding: 20px;\n}\n\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 40px;\n  background: rgba(26, 26, 26, 0.8);\n  backdrop-filter: blur(10px);\n  border-radius: var(--border-radius);\n  box-shadow: var(--shadow);\n  border: 1px solid var(--border-color);\n}\n\n.header {\n  text-align: center;\n  margin-bottom: 40px;\n  padding-bottom: 20px;\n  border-bottom: 1px solid var(--border-color);\n}\n\n.header h1 {\n  font-size: 32px;\n  font-weight: 700;\n  margin-bottom: 10px;\n  background: var(--gradient-primary);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  position: relative;\n  display: inline-block;\n}\n\n.header h1::after {\n  content: '';\n  position: absolute;\n  bottom: -5px;\n  left: 10%;\n  width: 80%;\n  height: 2px;\n  background: var(--gradient-primary);\n  border-radius: 1px;\n}\n\n.header-info {\n  color: var(--text-secondary);\n  font-size: 14px;\n  margin-top: 10px;\n}\n\n.category-section {\n  margin-bottom: 50px;\n  position: relative;\n}\n\n.category-section::before {\n  content: '';\n  position: absolute;\n  left: 0;\n  top: 0;\n  width: 4px;\n  height: 100%;\n  background: var(--gradient-primary);\n  border-radius: 2px;\n  opacity: 0.8;\n}\n\n.category-title {\n  font-size: 20px;\n  font-weight: 600;\n  margin-bottom: 20px;\n  color: var(--secondary-color);\n  padding-left: 15px;\n  position: relative;\n}\n\n.question-card {\n  background: var(--card-color);\n  border-radius: var(--border-radius);\n  padding: 25px;\n  margin-bottom: 20px;\n  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);\n  border: 1px solid var(--border-color);\n  transition: var(--transition);\n  position: relative;\n  overflow: hidden;\n}\n\n.question-card::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 2px;\n  background: var(--gradient-primary);\n  transform: scaleX(0);\n  transform-origin: left;\n  transition: transform 0.3s ease;\n}\n\n.question-card:hover {\n  transform: translateY(-2px);\n  box-shadow: var(--shadow);\n  border-color: var(--primary-color);\n}\n\n.question-card:hover::before {\n  transform: scaleX(1);\n}\n\n.question-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n  padding-bottom: 15px;\n  border-bottom: 1px solid var(--border-color);\n}\n\n.question-number {\n  font-size: 18px;\n  font-weight: 700;\n  color: var(--secondary-color);\n  margin: 0;\n  background: var(--gradient-primary);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.question-meta {\n  display: flex;\n  gap: 10px;\n  align-items: center;\n}\n\n.question-type {\n  background: rgba(0, 102, 255, 0.2);\n  color: var(--secondary-color);\n  padding: 4px 12px;\n  border-radius: 15px;\n  font-size: 12px;\n  border: 1px solid rgba(0, 204, 255, 0.3);\n}\n\n.difficulty-level {\n  background: rgba(255, 102, 0, 0.2);\n  color: var(--accent-color);\n  padding: 4px 12px;\n  border-radius: 15px;\n  font-size: 12px;\n  border: 1px solid rgba(255, 102, 0, 0.3);\n  font-weight: 600;\n}\n\n.question-content {\n  margin-bottom: 20px;\n}\n\n.question-text {\n  font-size: 16px;\n  line-height: 1.6;\n  margin-bottom: 20px;\n  color: var(--text-color);\n  font-weight: 500;\n}\n\n.options-grid {\n  display: grid;\n  gap: 12px;\n  margin: 20px 0;\n}\n\n.option-item {\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid var(--border-color);\n  border-radius: 8px;\n  padding: 12px 16px;\n  font-size: 14px;\n  color: var(--text-color);\n  transition: var(--transition);\n  cursor: pointer;\n  position: relative;\n  overflow: hidden;\n}\n\n.option-item:hover {\n  background: rgba(0, 102, 255, 0.1);\n  border-color: var(--primary-color);\n  transform: translateX(5px);\n}\n\n.option-item::before {\n  content: '';\n  position: absolute;\n  left: 0;\n  top: 0;\n  bottom: 0;\n  width: 3px;\n  background: var(--gradient-primary);\n  transform: scaleY(0);\n  transform-origin: center;\n  transition: transform 0.3s ease;\n}\n\n.option-item:hover::before {\n  transform: scaleY(1);\n}\n\n.question-actions {\n  display: flex;\n  gap: 10px;\n  margin-bottom: 20px;\n  flex-wrap: wrap;\n}\n\n.action-btn {\n  padding: 10px 20px;\n  border: none;\n  border-radius: 6px;\n  font-size: 14px;\n  font-weight: 500;\n  cursor: pointer;\n  transition: var(--transition);\n  position: relative;\n  overflow: hidden;\n  z-index: 1;\n}\n\n.action-btn::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: var(--gradient-primary);\n  transition: left 0.3s ease;\n  z-index: -1;\n}\n\n.action-btn:hover::before {\n  left: 0;\n}\n\n.show-answer {\n  background: var(--primary-color);\n  color: white;\n}\n\n.show-answer:hover {\n  color: white;\n  box-shadow: 0 4px 12px rgba(0, 102, 255, 0.4);\n}\n\n.show-explanation {\n  background: transparent;\n  color: var(--secondary-color);\n  border: 1px solid var(--secondary-color);\n}\n\n.show-explanation::before {\n  background: var(--gradient-accent);\n}\n\n.show-explanation:hover {\n  color: white;\n  box-shadow: 0 4px 12px rgba(255, 102, 0, 0.4);\n}\n\n.answer-section {\n  background: rgba(0, 255, 136, 0.05);\n  border: 1px solid rgba(0, 255, 136, 0.2);\n  border-radius: 8px;\n  padding: 20px;\n  margin-bottom: 20px;\n  display: none;\n  animation: fadeIn 0.3s ease;\n}\n\n.answer-section.visible {\n  display: block;\n}\n\n.correct-answer {\n  display: flex;\n  align-items: center;\n  margin-bottom: 15px;\n  padding: 12px;\n  background: rgba(0, 255, 136, 0.1);\n  border-radius: 6px;\n  border-left: 4px solid var(--success-color);\n}\n\n.answer-label {\n  font-weight: 600;\n  color: var(--success-color);\n  margin-right: 10px;\n  font-size: 14px;\n}\n\n.answer-value {\n  font-weight: 700;\n  color: var(--success-color);\n  font-size: 14px;\n}\n\n.explanation, .analysis, .hint {\n  margin-top: 15px;\n  padding: 15px;\n  border-radius: 6px;\n  border: 1px solid var(--border-color);\n  animation: slideIn 0.3s ease;\n}\n\n.explanation {\n  background: rgba(0, 102, 255, 0.05);\n  border-left: 4px solid var(--primary-color);\n}\n\n.analysis {\n  background: rgba(255, 102, 0, 0.05);\n  border-left: 4px solid var(--accent-color);\n}\n\n.hint {\n  background: rgba(255, 170, 0, 0.05);\n  border-left: 4px solid var(--warning-color);\n}\n\n.section-title {\n  font-size: 14px;\n  font-weight: 600;\n  margin-bottom: 8px;\n  color: var(--text-color);\n}\n\n.explanation p, .analysis p, .hint p {\n  font-size: 14px;\n  line-height: 1.5;\n  color: var(--text-secondary);\n  margin: 0;\n}\n\n.question-footer {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  padding-top: 15px;\n  border-top: 1px solid var(--border-color);\n  margin-top: 15px;\n}\n\n.footer-item {\n  background: rgba(255, 255, 255, 0.05);\n  color: var(--text-secondary);\n  padding: 4px 12px;\n  border-radius: 12px;\n  font-size: 12px;\n  border: 1px solid var(--border-color);\n  transition: var(--transition);\n}\n\n.footer-item:hover {\n  background: rgba(0, 102, 255, 0.1);\n  border-color: var(--primary-color);\n  color: var(--secondary-color);\n}\n\n.footer {\n  text-align: center;\n  margin-top: 50px;\n  padding-top: 20px;\n  border-top: 1px solid var(--border-color);\n  color: var(--text-secondary);\n  font-size: 14px;\n  position: relative;\n}\n\n.footer::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 30%;\n  width: 40%;\n  height: 1px;\n  background: var(--gradient-primary);\n  border-radius: 0.5px;\n}\n\n@keyframes fadeIn {\n  from {\n    opacity: 0;\n    transform: translateY(10px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes slideIn {\n  from {\n    opacity: 0;\n    transform: translateX(-10px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n\n@media (max-width: 768px) {\n  .container {\n    padding: 20px;\n  }\n  \n  .header h1 {\n    font-size: 24px;\n  }\n  \n  .question-card {\n    padding: 20px;\n  }\n  \n  .question-header {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 10px;\n  }\n  \n  .question-actions {\n    flex-direction: column;\n  }\n  \n  .action-btn {\n    width: 100%;\n    text-align: center;\n  }\n  \n  .options-grid {\n    grid-template-columns: 1fr;\n  }\n}\n</style>\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  // 显示/隐藏答案\n  document.querySelectorAll('.show-answer').forEach(button => {\n    button.addEventListener('click', function() {\n      const questionCard = this.closest('.question-card');\n      const answerSection = questionCard.querySelector('.answer-section');\n      const isVisible = answerSection.classList.contains('visible');\n      \n      answerSection.classList.toggle('visible');\n      this.textContent = isVisible ? '查看答案' : '隐藏答案';\n      this.classList.toggle('active', !isVisible);\n    });\n  });\n  \n  // 显示/隐藏解析\n  document.querySelectorAll('.show-explanation').forEach(button => {\n    button.addEventListener('click', function() {\n      const questionCard = this.closest('.question-card');\n      const explanation = questionCard.querySelector('.explanation');\n      const analysis = questionCard.querySelector('.analysis');\n      const hint = questionCard.querySelector('.hint');\n      \n      if (explanation) explanation.style.display = explanation.style.display === 'none' ? 'block' : 'none';\n      if (analysis) analysis.style.display = analysis.style.display === 'none' ? 'block' : 'none';\n      if (hint) hint.style.display = hint.style.display === 'none' ? 'block' : 'none';\n      \n      this.textContent = this.textContent === '查看解析' ? '隐藏解析' : '查看解析';\n      this.classList.toggle('active');\n    });\n  });\n  \n  // 为选项添加点击效果\n  document.querySelectorAll('.option-item').forEach(option => {\n    option.addEventListener('click', function() {\n      // 移除其他选项的选中状态\n      this.parentElement.querySelectorAll('.option-item').forEach(item => {\n        item.classList.remove('selected');\n      });\n      // 添加当前选项的选中状态\n      this.classList.add('selected');\n    });\n  });\n});\n</script>\n</head>\n<body>\n<div class=\"container\">\n<div class=\"header\">\n<h1>现代科技风格</h1>\n<div class=\"header-info\">\n<p>导出时间: {{exportTime}}</p>\n<p>题目数量: {{questionCount}}</p>\n</div>\n</div>\n{{questions}}\n<div class=\"footer\">\n<p>© 2026 现代科技风格导出</p>\n</div>\n</div>\n</body>\n</html>"
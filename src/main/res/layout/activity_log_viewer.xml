<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.activity.LogViewerActivity">

    <!-- 顶部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/surface"
        android:elevation="4dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_log"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="清空日志"
            android:textSize="12sp"
            app:backgroundTint="@color/error"
            android:textColor="@android:color/white"
            app:cornerRadius="20dp"
            android:layout_marginEnd="8dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_log"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="复制日志"
            android:textSize="12sp"
            app:backgroundTint="@color/primary"
            android:textColor="@android:color/white"
            app:cornerRadius="20dp"
            android:layout_marginEnd="8dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_log"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="分享日志"
            android:textSize="12sp"
            app:backgroundTint="@color/secondary"
            android:textColor="@android:color/white"
            app:cornerRadius="20dp"
            android:layout_marginEnd="8dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export_log"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="导出日志"
            android:textSize="12sp"
            app:backgroundTint="@color/tertiary"
            android:textColor="@android:color/white"
            app:cornerRadius="20dp"/>
    </LinearLayout>

    <!-- 搜索和筛选区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/surface_variant">
        <!-- 搜索框 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_search"
            app:endIconContentDescription="搜索">
            <EditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="搜索日志..."
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"/>
        </com.google.android.material.textfield.TextInputLayout>
        
        <!-- 筛选按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="全部"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/primary_container"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="false"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模型信息"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/secondary_container"
                app:chipStrokeColor="@color/secondary"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="false"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="错误信息"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/error_container"
                app:chipStrokeColor="@color/error"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="false"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_success"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="成功信息"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/success_container"
                app:chipStrokeColor="@color/success"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="false"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_ai_service"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI服务"
                app:chipBackgroundColor="@color/primary_container"
                app:chipStrokeColor="@color/primary"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="false"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 标签页区域 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:tabMode="scrollable"
        app:tabGravity="fill">
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="所有日志"/>
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="模型信息"/>
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="错误信息"/>
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="成功信息"/>
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="详细信息"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- 主日志显示区域 -->
    <ScrollView
        android:id="@+id/log_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- 日志列表 -->
            <ListView
                android:id="@+id/log_list_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@color/on_surface"
                android:dividerHeight="1dp"/>
            
            <!-- 详细信息区域 -->
            <LinearLayout
                android:id="@+id/detailed_info_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/surface_variant"
                android:visibility="gone">
                <TextView
                    android:id="@+id/detailed_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="详细信息"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"/>
                <TextView
                    android:id="@+id/detailed_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@color/surface"
                    android:padding="12dp"
                    android:minHeight="120dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_close_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="关闭"
                    android:textSize="12sp"
                    app:backgroundTint="@color/primary"
                    android:textColor="@color/on_primary"
                    app:cornerRadius="20dp"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 信息输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/surface"
        android:elevation="8dp">
        <EditText
            android:id="@+id/input_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入消息..."
            android:padding="12dp"
            android:background="@drawable/rounded_edittext"
            android:maxLines="3"
            android:inputType="textMultiLine"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginEnd="8dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/on_primary"/>
    </LinearLayout>

</LinearLayout>

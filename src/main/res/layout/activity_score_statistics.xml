<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_ultra_light"
    tools:context=".ScoreStatisticsActivity">

    <!-- 顶部状态栏 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_700"
        app:title="成绩统计"
        app:titleTextColor="@color/white"
        android:elevation="4dp"
        android:translationZ="4dp" />

    <!-- 主要内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 统计卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_card"
                android:padding="20dp"
                android:elevation="4dp"
                android:translationZ="4dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="总体统计"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/purple_700"
                    android:layout_marginBottom="20dp" />

                <!-- 统计数据网格 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 第一行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rounded_card"
                            android:padding="16dp"
                            android:elevation="2dp"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="平均分"
                                android:textSize="14sp"
                                android:textColor="@color/gray_600"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/textViewAverageScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/purple_600" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rounded_card"
                            android:padding="16dp"
                            android:elevation="2dp"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="总次数"
                                android:textSize="14sp"
                                android:textColor="@color/gray_600"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/textViewTotalAttempts"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal_600" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rounded_card"
                            android:padding="16dp"
                            android:elevation="2dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="最高分"
                                android:textSize="14sp"
                                android:textColor="@color/gray_600"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/textViewBestScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/green_600" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 第二行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rounded_card"
                            android:padding="16dp"
                            android:elevation="2dp"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="最近分"
                                android:textSize="14sp"
                                android:textColor="@color/gray_600"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/textViewRecentScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/orange_600" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rounded_card"
                            android:padding="16dp"
                            android:elevation="2dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="平均用时"
                                android:textSize="14sp"
                                android:textColor="@color/gray_600"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/textViewAverageTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0:00"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/blue_600" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 分析卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- 分类分析 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/rounded_card"
                    android:padding="20dp"
                    android:elevation="4dp"
                    android:translationZ="4dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="分类分析"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_700"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/textViewCategoryAnalysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无数据"
                        android:textSize="14sp"
                        android:textColor="@color/gray_600"
                        android:lineSpacingExtra="6sp" />
                </LinearLayout>

                <!-- 题型分析 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/rounded_card"
                    android:padding="20dp"
                    android:elevation="4dp"
                    android:translationZ="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="题型分析"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_700"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/textViewTypeAnalysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无数据"
                        android:textSize="14sp"
                        android:textColor="@color/gray_600"
                        android:lineSpacingExtra="6sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 历史记录 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_card"
                android:padding="20dp"
                android:elevation="4dp"
                android:translationZ="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="历史记录"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/purple_700"
                    android:layout_marginBottom="20dp" />

                <!-- 历史记录列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewScoreHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="300dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
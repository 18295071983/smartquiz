<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_gray"
    tools:context=".X5KernelStatusActivity">

    <!-- 标题栏 -->
    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/teal_500"
        app:title="X5内核状态"
        app:titleTextColor="@color/white">
    </androidx.appcompat.widget.Toolbar>

    <!-- 主要内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 状态信息滚动视图 -->
        <ScrollView
            android:id="@+id/scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/rounded_card"
            android:elevation="4dp"
            android:padding="20dp"
            android:scrollbars="vertical">

            <!-- 状态信息文本 -->
            <TextView
                android:id="@+id/tv_status_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:lineSpacingExtra="4sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif" />

        </ScrollView>

        <!-- 按钮栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="刷新状态"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white"
                android:background="@drawable/rounded_corners_teal"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null"
                android:elevation="2dp" />

            <Button
                android:id="@+id/btn_clear"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="清空日志"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white"
                android:background="@drawable/rounded_corners_gray"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null"
                android:elevation="2dp" />

            <Button
                android:id="@+id/btn_restart"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="重启内核"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white"
                android:background="@drawable/rounded_corners_red"
                android:layout_marginStart="8dp"
                android:stateListAnimator="@null"
                android:elevation="2dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

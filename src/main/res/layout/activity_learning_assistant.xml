<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.activity.LearningAssistantActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:title="学习助手"
            app:titleTextColor="@color/text_primary"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="助手模式"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp"/>
                    
                    <RadioGroup
                        android:id="@+id/assistant_mode_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RadioButton
                            android:id="@+id/radio_learning_plan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="学习计划"
                            android:checked="true"/>
                        <RadioButton
                            android:id="@+id/radio_concept_explanation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="概念解释"/>
                        <RadioButton
                            android:id="@+id/radio_exam_preparation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="考试准备"/>
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/plan_mode_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="学习计划设置"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>
                    
                    <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_subject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="科目">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_subject_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"/>
                </com.google.android.material.textfield.TextInputLayout>
                
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_weekly_hours"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="每周学习小时数">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_weekly_hours_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"/>
                </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/plan_difficulty_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="难度"/>
                    
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generate_plan"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="生成计划"
                        app:backgroundTint="@color/primary"
                        android:textColor="@color/on_primary"
                        app:cornerRadius="12dp"
                        android:textAllCaps="false"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/concept_mode_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="概念解释设置"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/input_concept"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="概念">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_concept_edit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/concept_difficulty_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="难度"/>
                    
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_explain_concept"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="解释概念"
                        app:backgroundTint="@color/primary"
                        android:textColor="@color/on_primary"
                        app:cornerRadius="12dp"
                        android:textAllCaps="false"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/exam_mode_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="考试准备设置"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/input_exam_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="考试类型">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_exam_type_edit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/input_days_left"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="剩余天数">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_days_left_edit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generate_preparation"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="生成准备计划"
                        app:backgroundTint="@color/primary"
                        android:textColor="@color/on_primary"
                        app:cornerRadius="12dp"
                        android:textAllCaps="false"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/result_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="结果"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>
                    
                    <LinearLayout
                        android:id="@+id/loadingLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <ProgressBar
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/loading_message"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="加载中..."
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/loading_submessage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="8dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cancel"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="取消"
                            app:backgroundTint="@color/error"
                            android:textColor="@color/on_error"
                            app:cornerRadius="12dp"
                            android:textAllCaps="false"/>
                    </LinearLayout>
                    
                    <LinearLayout
                        android:id="@+id/result_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/result_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="生成的内容将显示在这里"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="16dp"/>
                    </LinearLayout>
                    
                    <LinearLayout
                        android:id="@+id/actions_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_save_assistant"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="保存"
                            app:backgroundTint="@color/primary"
                            android:textColor="@color/on_primary"
                            app:cornerRadius="12dp"
                            android:textAllCaps="false"
                            android:layout_marginEnd="8dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_share_assistant"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="分享"
                            app:backgroundTint="@color/secondary"
                            android:textColor="@color/on_secondary"
                            app:cornerRadius="12dp"
                            android:textAllCaps="false"
                            android:layout_marginEnd="8dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_assistant"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="复制"
                            app:backgroundTint="@color/secondary"
                            android:textColor="@color/on_secondary"
                            app:cornerRadius="12dp"
                            android:textAllCaps="false"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
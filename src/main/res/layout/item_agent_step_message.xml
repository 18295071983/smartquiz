<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/step_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/step_type_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/agent_step_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/step_iteration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/agent_step_label" />

    </LinearLayout>

    <TextView
        android:id="@+id/step_thought"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/agent_thinking_background"
        android:padding="10dp"
        android:textColor="@color/agent_step_text"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/step_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/agent_action_background"
        android:padding="10dp"
        android:textColor="@color/agent_step_text"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/step_observation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/agent_observation_background"
        android:padding="10dp"
        android:textColor="@color/agent_step_text"
        android:textSize="13sp"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/step_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="4dp"
        android:max="100"
        android:progress="0"
        android:visibility="gone" />

</LinearLayout>

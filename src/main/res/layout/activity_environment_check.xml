<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.activity.EnvironmentCheckActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:titleTextColor="@color/on_surface" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <!-- 检测状态 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary_container"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_check_circle"
                        android:tint="@color/on_primary_container"
                        android:layout_marginEnd="16dp" />
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="环境检测完成"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_primary_container"
                            android:layout_marginBottom="4dp" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="设备环境正常，可以运行应用"
                            android:textSize="14sp"
                            android:textColor="@color/on_primary_container" />
                        
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 设备信息 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设备信息"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/surface_variant"
                            android:layout_marginBottom="12dp" />
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="制造商"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_manufacturer"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="品牌"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_brand"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="型号"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_model"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="硬件"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_hardware"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 系统信息 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="系统信息"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/surface_variant"
                            android:layout_marginBottom="12dp" />
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Android版本"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_android_version"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="SDK级别"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_sdk_int"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="安全补丁"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_security_patch"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="语言"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_language"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 硬件信息 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="硬件信息"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/surface_variant"
                            android:layout_marginBottom="12dp" />
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="CPU架构"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_cpu_abi"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="处理器数量"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_processors"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="相机"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_camera"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="GPS"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_gps"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 内存信息 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="内存信息"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/surface_variant"
                            android:layout_marginBottom="12dp" />
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="总内存"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_total_memory"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="可用内存"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_available_memory"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 存储信息 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="存储信息"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="12dp" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/surface_variant"
                            android:layout_marginBottom="12dp" />
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="内部存储"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_internal_storage"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="外部存储"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface_variant" />
                            
                            <TextView
                                android:id="@+id/tv_external_storage"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:text="-"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"
                                android:textStyle="bold" />
                            
                        </LinearLayout>
                        
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
        </LinearLayout>
        
    </ScrollView>

    <!-- 底部操作按钮 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="16dp"
        android:layout_margin="16dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_copy"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="复制信息"
                app:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp"
                app:cornerRadius="12dp"
                android:textAllCaps="false"/>
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="分享报告"
                app:backgroundTint="@color/secondary"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                android:textAllCaps="false"/>
            
        </LinearLayout>
        
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

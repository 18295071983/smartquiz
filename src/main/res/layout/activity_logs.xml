<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.activity.LogsActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:title="系统日志"
        app:titleTextColor="?attr/colorOnSurface"
        app:menu="@menu/logs_menu"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:tabTextColor="?attr/colorOnSurface"
        app:tabSelectedTextColor="?attr/colorPrimary"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

    <LinearLayout
        android:id="@+id/ll_pagination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface"
        android:gravity="center">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_prev_page"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="上一页"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            app:cornerRadius="12dp"/>
        <TextView
            android:id="@+id/tv_page_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:text="第 1 页，共 1 页"
            android:textColor="@color/text_primary"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_page"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="下一页"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/surface"
        android:elevation="8dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_refresh_logs"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="刷新"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            app:cornerRadius="12dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_logs"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="清空"
            android:textAllCaps="false"
            app:backgroundTint="@color/error"
            android:textColor="@color/on_error"
            app:cornerRadius="12dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_logs"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="复制"
            android:textAllCaps="false"
            app:backgroundTint="@color/secondary"
            android:textColor="@color/on_secondary"
            app:cornerRadius="12dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export_logs"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="导出"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            app:cornerRadius="12dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_logs"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="分享"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            app:cornerRadius="12dp"/>
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.activity.AgentChatActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:titleTextColor="@color/text_primary">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp"
                    app:backgroundTint="@color/surface_variant"
                    app:icon="@drawable/ic_back"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:cornerRadius="16dp"
                    android:contentDescription="返回"/>
                <TextView
                    android:id="@+id/toolbar_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Agent助手"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_model_select"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="选择模型"
                    android:textSize="12sp"
                    app:backgroundTint="@color/primary"
                    android:textColor="@color/on_primary"
                    app:cornerRadius="16dp"
                    android:textAllCaps="false"
                    android:layout_marginEnd="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_history"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:backgroundTint="@color/surface_variant"
                    app:icon="@drawable/ic_clear"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:cornerRadius="16dp"
                    android:contentDescription="清除历史"/>
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@color/surface_variant">
        <TextView
            android:id="@+id/model_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未选择模型"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center_vertical"/>
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_task_list"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="任务列表"
            android:textSize="12sp"
            app:backgroundTint="@color/secondary"
            android:textColor="@color/on_secondary"
            app:cornerRadius="16dp"
            android:textAllCaps="false"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/message_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"/>

    <View
        android:id="@+id/thinking_indicator"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/primary"
        android:visibility="gone"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/quick_actions_chip_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface_variant"
        android:visibility="gone">
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_create_task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="创建任务"
            android:layout_marginEnd="8dp"
            app:chipBackgroundColor="@color/primary"
            android:textColor="@color/on_primary"/>
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_learn_plan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="学习计划"
            android:layout_marginEnd="8dp"
            app:chipBackgroundColor="@color/secondary"
            android:textColor="@color/on_secondary"/>
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_problem_solve"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="问题解决"
            android:layout_marginEnd="8dp"
            app:chipBackgroundColor="@color/primary"
            android:textColor="@color/on_primary"/>
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_optimize_task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="优化任务"
            app:chipBackgroundColor="@color/secondary"
            android:textColor="@color/on_secondary"/>
    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/surface"
        android:elevation="8dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/rounded_edittext"
            android:gravity="center_vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_attach"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:backgroundTint="@android:color/transparent"
                app:icon="@drawable/ic_attach"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:contentDescription="附加"
                android:layout_marginStart="8dp"/>
            <EditText
                android:id="@+id/input_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="输入任务..."
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:textColor="@color/text_primary"
                android:layout_marginHorizontal="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_voice"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:backgroundTint="@android:color/transparent"
                app:icon="@drawable/ic_voice"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:contentDescription="语音"
                android:layout_marginEnd="8dp"/>
        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:contentDescription="发送"/>
    </LinearLayout>

</LinearLayout>
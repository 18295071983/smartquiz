<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.activity.ExportActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:title="导出功能"
            app:titleTextColor="@color/on_surface"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            
            <!-- 欢迎卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary_container"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_export"
                        android:tint="@color/on_primary_container"
                        android:layout_marginEnd="16dp" />
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="数据导出"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_primary_container"
                            android:layout_marginBottom="4dp" />
                        
                        <TextView
                            android:id="@+id/textQuestionCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="当前题库共有 0 道题目"
                            android:textSize="14sp"
                            android:textColor="@color/on_primary_container" />
                        
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 导出格式选择 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="导出格式"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="16dp" />
                    
                    <Spinner
                        android:id="@+id/spinner_export_format"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_spinner"
                        android:padding="12dp" />
                        
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 导出选项 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="导出选项"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="16dp" />
                    
                    <CheckBox
                        android:id="@+id/cb_include_answers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="包含答案"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />
                        
                    <CheckBox
                        android:id="@+id/cb_include_explanations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="包含解析"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />
                        
                    <CheckBox
                        android:id="@+id/cb_include_difficulty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="包含难度"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />
                        
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 导出设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="高级设置"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="16dp" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="导出范围"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface" />
                            
                        <Spinner
                            android:id="@+id/spinner_export_scope"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/rounded_spinner"
                            android:padding="12dp" />
                            
                    </LinearLayout>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="文件命名"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface" />
                            
                        <Spinner
                            android:id="@+id/spinner_naming_convention"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/rounded_spinner"
                            android:padding="12dp" />
                            
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 字段选择 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="字段选择"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="16dp" />
                        
                    <TextView
                        android:id="@+id/tv_selected_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="已选择字段: 无"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginBottom="16dp" />
                        
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_select_fields"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="选择字段"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/primary"
                            android:textColor="@android:color/white"
                            android:layout_marginEnd="8dp"
                            app:cornerRadius="12dp"
                            android:textAllCaps="false" />
                            
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_select_template"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="选择模板"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/secondary"
                            android:textColor="@android:color/white"
                            app:cornerRadius="12dp"
                            android:textAllCaps="false" />
                            
                    </LinearLayout>
                    
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
            <!-- 提示信息 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_variant"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="提示信息"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• 导出前请确保有足够的存储空间\n• 大批量导出可能需要较长时间"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:lineSpacingExtra="4dp" />
                        
                    <TextView
                        android:id="@+id/tvExportDirectory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp"
                        android:padding="8dp"
                        android:background="@color/surface"
                        android:fontFamily="monospace" />
                        
                </LinearLayout>
                
            </com.google.android.material.card.MaterialCardView>
            
        </LinearLayout>
        
    </ScrollView>

    <!-- 底部操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/surface"
        android:elevation="8dp">
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_export"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="开始导出"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="12dp"
            android:textAllCaps="false" />
            
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.activity.AIChatActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="0dp"
            app:elevation="0dp">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/surface"
                app:titleTextColor="@color/text_primary">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_back"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="12dp"
                        app:backgroundTint="@color/surface_variant"
                        app:icon="@drawable/ic_back"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:cornerRadius="18dp"
                        app:iconTint="@color/text_primary"
                        android:contentDescription="返回"/>
                    <TextView
                        android:id="@+id/toolbar_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AI助手"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_model_select"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="选择模型"
                        android:textSize="12sp"
                        app:backgroundTint="@color/primary"
                        android:textColor="@color/on_primary"
                        app:cornerRadius="18dp"
                        android:textAllCaps="false"
                        android:layout_marginEnd="8dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_history"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="4dp"
                        app:backgroundTint="@color/surface_variant"
                        app:icon="@drawable/ic_history"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:cornerRadius="18dp"
                        app:iconTint="@color/text_primary"
                        android:contentDescription="历史"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_chat"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:backgroundTint="@color/surface_variant"
                        app:icon="@drawable/ic_clear"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:cornerRadius="18dp"
                        app:iconTint="@color/text_primary"
                        android:contentDescription="清空"/>
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="@color/surface_variant">
            <TextView
                android:id="@+id/model_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未选择模型"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_gravity="center_vertical"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <TextView
                android:id="@+id/current_mode_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 普通模式"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop_generation"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="停止生成"
                android:textSize="12sp"
                app:backgroundTint="@color/error"
                android:textColor="@color/on_error"
                app:cornerRadius="18dp"
                android:textAllCaps="false"
                android:visibility="gone"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_log_viewer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                app:backgroundTint="@color/surface_variant"
                app:icon="@drawable/ic_log"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="18dp"
                app:iconTint="@color/text_primary"
                android:contentDescription="日志"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/surface_variant">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mode_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:clipToPadding="false"/>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/weather_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:background="@drawable/weather_banner_background"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/weather_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️"
                android:textSize="28sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/weather_city"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="定位中..."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/weather_banner_text" />

                    <TextView
                        android:id="@+id/weather_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°C"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/weather_banner_text"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/weather_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="加载中..."
                    android:textSize="12sp"
                    android:textColor="@color/weather_banner_text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/weather_humidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="湿度: --%"
                    android:textSize="11sp"
                    android:textColor="@color/weather_banner_text_secondary" />

                <TextView
                    android:id="@+id/weather_wind"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="风速: -- m/s"
                    android:textSize="11sp"
                    android:textColor="@color/weather_banner_text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_weather_refresh"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                app:backgroundTint="#33FFFFFF"
                app:icon="@drawable/ic_refresh"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="16dp"
                app:iconTint="@color/weather_banner_text"
                app:iconSize="16dp"
                android:contentDescription="刷新天气" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_weather_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                app:backgroundTint="#33FFFFFF"
                app:icon="@drawable/ic_clear"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="16dp"
                app:iconTint="@color/weather_banner_text"
                app:iconSize="14dp"
                android:contentDescription="关闭天气" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/message_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:clipToPadding="false"/>

        <View
            android:id="@+id/thinking_indicator"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/gradient_primary"
            android:visibility="gone"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/quick_actions_chip_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@color/surface_variant"
            android:visibility="gone">
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总结对话"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/primary"
                android:textColor="@color/on_primary"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_translate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="翻译"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/secondary"
                android:textColor="@color/on_secondary"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_code_explain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="代码解释"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/primary"
                android:textColor="@color/on_primary"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_optimize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="优化文本"
                app:chipBackgroundColor="@color/secondary"
                android:textColor="@color/on_secondary"/>
        </com.google.android.material.chip.ChipGroup>

        <LinearLayout
            android:id="@+id/loadingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="@color/surface"
            android:visibility="gone">
            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:indeterminateTint="@color/primary"/>
            <TextView
                android:id="@+id/loading_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI正在思考..."
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"/>
            <TextView
                android:id="@+id/loading_submessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请稍候，AI正在生成回答..."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="取消生成"
                app:backgroundTint="@color/error"
                android:textColor="@color/on_error"
                app:cornerRadius="22dp"
                android:textAllCaps="false"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/log_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="处理日志"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_log"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="清空"
                    android:textSize="11sp"
                    app:backgroundTint="@color/surface_variant"
                    android:textColor="@color/text_secondary"
                    app:cornerRadius="16dp"
                    android:textAllCaps="false"
                    android:layout_marginEnd="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_toggle_log"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="收起"
                    android:textSize="11sp"
                    app:backgroundTint="@color/surface_variant"
                    android:textColor="@color/text_secondary"
                    app:cornerRadius="16dp"
                    android:textAllCaps="false"/>
            </LinearLayout>
            <ScrollView
                android:id="@+id/log_scroll"
                android:layout_width="match_parent"
                android:layout_height="140dp">
                <TextView
                    android:id="@+id/log_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"
                    android:padding="12dp"/>
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:elevation="8dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/attachment_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:visibility="gone"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_variant"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:background="@drawable/rounded_edittext"
                android:gravity="center_vertical">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_attach"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:backgroundTint="@android:color/transparent"
                        app:icon="@drawable/ic_attach"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/text_secondary"
                        android:contentDescription="附加"
                        android:layout_marginStart="8dp"/>
                    <EditText
                        android:id="@+id/input_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="输入消息..."
                        android:padding="14dp"
                        android:background="@android:color/transparent"
                        android:maxLines="5"
                        android:inputType="textMultiLine"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:layout_marginHorizontal="8dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_guide"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:backgroundTint="@android:color/transparent"
                        app:icon="@drawable/ic_help"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/text_secondary"
                        android:contentDescription="使用指南"
                        android:layout_marginEnd="4dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_voice"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:backgroundTint="@android:color/transparent"
                        app:icon="@drawable/ic_voice"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/text_secondary"
                        android:contentDescription="语音"
                        android:layout_marginEnd="8dp"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="14dp"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="28dp"
                    app:icon="@drawable/ic_send"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@color/on_primary"
                    android:contentDescription="发送"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/history_drawer"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/surface"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@color/surface_variant">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="对话历史"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_close_history"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:backgroundTint="@color/surface_variant"
                    app:icon="@drawable/ic_clear"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:cornerRadius="18dp"
                    app:iconTint="@color/text_primary"
                    android:contentDescription="关闭"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/history_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:clipToPadding="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_all_history"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_margin="12dp"
                android:text="清空所有历史"
                android:textSize="14sp"
                app:backgroundTint="@color/error"
                android:textColor="@color/on_error"
                app:cornerRadius="22dp"
                android:textAllCaps="false"/>
        </LinearLayout>
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/gray_ultra_light"
    tools:context=".OllamaServiceActivity">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="20dp">

        <Button
            android:id="@+id/buttonBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:drawableStart="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ollama服务管理"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:textColor="@color/purple_700" />
    </LinearLayout>

    <!-- 状态显示区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_card"
        android:padding="20dp"
        android:layout_marginBottom="16dp"
        android:elevation="4dp"
        android:translationZ="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务状态:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginRight="12dp" />

            <TextView
                android:id="@+id/textViewStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="未运行"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/red_600" />

            <View
                android:id="@+id/statusIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_indicator_red"
                android:layout_marginLeft="12dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/textViewStatusMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="状态详情: 服务未启动"
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="16dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 操作按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/buttonStartService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="启动Ollama服务"
            android:textSize="16sp"
            android:padding="16dp"
            android:background="@drawable/rounded_corners_blue"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"
            android:elevation="3dp"
            android:translationZ="3dp" />

        <Button
            android:id="@+id/buttonStopService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="停止Ollama服务"
            android:textSize="16sp"
            android:padding="16dp"
            android:background="@drawable/rounded_corners_gray"
            android:textColor="@android:color/black"
            android:layout_marginBottom="12dp"
            android:elevation="3dp"
            android:translationZ="3dp" />

        <Button
            android:id="@+id/buttonCheckStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="检查服务状态"
            android:textSize="16sp"
            android:padding="16dp"
            android:background="@drawable/rounded_corners_gray"
            android:textColor="@android:color/black"
            android:layout_marginBottom="12dp"
            android:elevation="3dp"
            android:translationZ="3dp" />
        
        <Button
            android:id="@+id/buttonInitializeMLC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="初始化MLC-LLM"
            android:textSize="16sp"
            android:padding="16dp"
            android:background="@drawable/rounded_corners_teal"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"
            android:elevation="3dp"
            android:translationZ="3dp" />
    </LinearLayout>
    
    <!-- MLC-LLM状态显示区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_card"
        android:padding="20dp"
        android:layout_marginBottom="16dp"
        android:elevation="4dp"
        android:translationZ="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MLC-LLM状态:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginRight="12dp" />

            <TextView
                android:id="@+id/textViewMLCStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="未配置"
                android:textSize="16sp"
                android:textColor="@color/orange_600" />

            <View
                android:id="@+id/mlcStatusIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_indicator_orange"
                android:layout_marginLeft="12dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 模型下载区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_card"
        android:padding="20dp"
        android:layout_marginBottom="16dp"
        android:elevation="4dp"
        android:translationZ="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="模型下载"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            android:textColor="@color/purple_700" />

        <Spinner
            android:id="@+id/spinnerModelSelect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/rounded_edittext"
            android:paddingHorizontal="16dp"
            android:dropDownVerticalOffset="8dp" />

        <Button
            android:id="@+id/buttonDownloadModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="下载模型"
            android:textSize="16sp"
            android:padding="16dp"
            android:background="@drawable/rounded_corners_teal"
            android:textColor="@android:color/white"
            android:elevation="3dp"
            android:translationZ="3dp" />
    </LinearLayout>

    <!-- 日志显示区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:elevation="4dp"
            android:translationZ="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="日志信息"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:textColor="@color/purple_700" />

            <TextView
                android:id="@+id/textViewLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="日志信息将显示在这里..."
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
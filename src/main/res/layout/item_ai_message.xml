<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/block_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="2dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/thinking_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💭 思考过程"
                android:textSize="11sp"
                android:textColor="@color/thinking_text"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/thinking_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/thinking_message_background"
                android:padding="10dp"
                android:textColor="@color/thinking_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/message_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginRight="48dp"
                android:background="@drawable/ai_message_background"
                android:padding="16dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textIsSelectable="true" />

        </LinearLayout>

        <ImageView
            android:id="@+id/btn_tts"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="TTS"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <TextView
            android:id="@+id/btn_expand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="展开全文"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:padding="4dp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/action_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/btn_copy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="复制"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:padding="4dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/btn_share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="分享"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:padding="4dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/btn_regenerate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="重新生成"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:padding="4dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/btn_new_chat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新对话"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:padding="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <ImageView
                android:id="@+id/status_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/timestamp_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="8dp" />

        </LinearLayout>

</LinearLayout>

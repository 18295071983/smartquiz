<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/mode_selected_background"/>
            <corners android:radius="18dp"/>
            <stroke android:width="1.5dp" android:color="@color/mode_selected_border"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/mode_unselected_background"/>
            <corners android:radius="18dp"/>
            <stroke android:width="0.5dp" android:color="@color/mode_unselected_border"/>
        </shape>
    </item>
</selector>

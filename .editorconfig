# EditorConfig - 统一编辑器配置
# 确保所有开发者使用相同的编码和格式设置
# https://editorconfig.org

root = true

# 所有文件的默认设置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Java 文件
[*.java]
charset = utf-8
indent_style = space
indent_size = 4

# XML 文件
[*.xml]
charset = utf-8
indent_style = space
indent_size = 4

# Gradle 文件
[*.gradle]
charset = utf-8
indent_style = space
indent_size = 4

# JSON 文件
[*.json]
charset = utf-8
indent_style = space
indent_size = 2

# Markdown 文件
[*.md]
charset = utf-8
trim_trailing_whitespace = false

# Shell 脚本
[*.sh]
charset = utf-8
end_of_line = lf

# Bat 脚本（Windows）
[*.bat]
charset = utf-8
end_of_line = crlf

# Python 文件
[*.py]
charset = utf-8
indent_style = space
indent_size = 4

# Properties 文件
[*.properties]
charset = utf-8

# HTML/CSS/JS 文件
[*.{html,css,js}]
charset = utf-8
indent_style = space
indent_size = 2
